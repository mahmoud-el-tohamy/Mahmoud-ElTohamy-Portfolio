{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaFeatures": {
      "jsx": true
    },
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": [
      "warn",
      {
        "varsIgnorePattern": "^React$|^[A-Z]",
        "argsIgnorePattern": "^React$|^[A-Z]|^pageProps$"
      }
    ],
    "no-empty-pattern": "off"
  }
}
